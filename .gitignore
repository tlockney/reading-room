# Build artifacts — regenerated by `deno task build`; the live server
# (`deno task serve`) renders dynamically and never reads these.
/docs/
/index.html

# LaunchAgent logs (agent.sh)
.agent.out.log
.agent.err.log

# Scratch space for importing docs (raw html, defuddled md, assembled editorial)
/_work/

# Remote-publish staging (deno task publish)
/.publish/
